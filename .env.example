# Copy to .env and adjust for your environment.
# docker compose reads .env automatically; both services receive their relevant vars.

# ---- Backend (api) ----
# Comma-separated list of allowed CORS origins. The wildcard "*" is rejected
# at startup — combined with credentialed CORS reflection it would allow any
# third-party site to read this API in the user's browser. List the exact
# origins the iPad will hit (LAN hostname, Tailscale name, etc).
# See docs/audits/security-report.md S1.
API_CORS_ORIGINS=http://localhost:3000,http://mac-mini.local:3000

# Set to "fixture" to make POST /api/cards/{day}/refresh and
# POST /api/odds/{day}/refresh load static JSON from fixtures/pick5/
# instead of hitting Equibase / TwinSpires. Useful for testing the full
# Pick 5 workflow before live entries / odds are published. The query
# param ?source=fixture overrides per-request.
# PICK5_DATA_MODE=fixture

# ---- Frontend (web) ----
# Used by Next.js server-side fetches (inside the docker network). The browser
# hits the same-origin /api proxy defined in web/next.config.mjs, so no
# separate public base URL is needed.
API_BASE_URL=http://api:8000
