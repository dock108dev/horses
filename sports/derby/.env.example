# Copy to .env and adjust for your environment.
# docker compose reads .env automatically; both services receive their relevant vars.

# ---- Backend (api) ----
# Comma-separated list of allowed CORS origins. The wildcard "*" is rejected
# at startup — combined with credentialed CORS reflection it would allow any
# third-party site to read this API in the user's browser. List the exact
# origins the iPad will hit (LAN hostname, Tailscale name, etc).
# See docs/audits/security-report.md S1.
API_CORS_ORIGINS=http://localhost:3000,http://mac-mini.local:3000

# SQLAlchemy/aiosqlite URL. The default points to the volume-mounted /data inside the container.
DATABASE_URL=sqlite+aiosqlite:////data/derby.db

# ---- Frontend (web) ----
# Used by Next.js server-side fetches (inside the docker network).
API_BASE_URL=http://api:8000

# Used by browser-side fetches. On the iPad this should be the host's reachable URL,
# e.g. http://mac-mini.local:8000 when accessing the app at http://mac-mini.local:3000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
